function addEvent(){
  const p=cp();if(!p)return;
  const date=document.getElementById('ev-d').value;
  const type=document.getElementById('ev-t').value;
  const maha=document.getElementById('ev-m').value;
  const antar=document.getElementById('ev-a').value;
  const pratyantar=document.getElementById('ev-p').value;
  if(!date||!type){toast('Date and event type required');return;}
  p.events.push({id:uid(),date,type,maha,antar,pratyantar});save();renderSidebar();
  const evs=(p.events||[]).slice().sort((a,b)=>(a.date||'').localeCompare(b.date||''));
  document.getElementById('ev-list').innerHTML=evs.map(ev=>evRow(ev,p)).join('');
  document.getElementById('ev-count-lbl').textContent=p.events.length+' RECORDED';
