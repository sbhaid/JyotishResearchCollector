function delEvent(eid){
  const p=cp();if(!p)return;
  if(!confirm('Delete?'))return;
  p.events=p.events.filter(e=>e.id!==eid);save();renderSidebar();
  const evs=(p.events||[]).slice().sort((a,b)=>(a.date||'').localeCompare(b.date||''));
  document.getElementById('ev-list').innerHTML=!evs.length?'<div style="color:#7a7268;font-size:13px;padding:10px 0;font-style:italic">No events yet</div>':evs.map(ev=>evRow(ev,p)).join('');
