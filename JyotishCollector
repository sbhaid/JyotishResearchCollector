// ── PLANET HOUSE LOGIC ───────────────────────────────────────────────
// Which signs does each planet own
const PLANET_OWNS = {
  Sun:['Leo'], Moon:['Cancer'], Mars:['Aries','Scorpio'],
  Mercury:['Gemini','Virgo'], Jupiter:['Sagittarius','Pisces'],
  Venus:['Taurus','Libra'], Saturn:['Capricorn','Aquarius'],
  Rahu:['Aquarius','Virgo'], Ketu:['Scorpio','Pisces']
};
// Joint ownership: Rahu co-owns Aquarius (w/Saturn) & Virgo (w/Mercury)
// Ketu co-owns Scorpio (w/Mars) & Pisces (w/Jupiter)

// For a given planet and varga chart data, return {sits, owns}
// sits = house number planet occupies
// owns = house numbers planet rules
function planetHouseInfo(planet, varData) {
  if(!varData) return null;
  const lagnaPos = varData['Lagna'];
  if(!lagnaPos) return null;
  const lagnaIdx = SIGNS.indexOf(lagnaPos.sign);
  const signToHouse = {};
  for(let h=1;h<=12;h++) signToHouse[SIGNS[(lagnaIdx+h-1)%12]] = h;

  // Sits in
  const pos = varData[planet];
  const sits = pos ? (signToHouse[pos.sign] || '?') : '?';

  // Owns
  const ownedSigns = PLANET_OWNS[planet] || [];
  const owns = ownedSigns.map(s => signToHouse[s] || '?').filter(h => h !== '?');

  return { sits, owns: owns.length ? owns.join(',') : '—' };
}

// Build the expandable dasha detail table for an event
function dashaDetailHTML(ev, p) {
  const dashaPlants = [
    { label: 'Maha', planet: ev.maha },
    { label: 'Antar', planet: ev.antar },
    { label: 'Pratyantar', planet: ev.pratyantar },
  ].filter(d => d.planet);
  if(!dashaPlants.length) return '<div style="color:#aaa;font-size:11px;font-style:italic">No dasha recorded</div>';

  const vargas = ['D-1','D-9','D-10 (Trd)'];
  const vLabels = {'D-1':'D1','D-9':'D9','D-10 (Trd)':'D10'};

  let html = '<table><thead><tr><th>Dasha</th><th>Planet</th>';
  vargas.forEach(v => {
    html += `<th>${vLabels[v]} Sits</th><th>${vLabels[v]} Owns</th>`;
  });
  html += '</tr></thead><tbody>';

  dashaPlants.forEach(({label, planet}) => {
    html += `<tr><td style="color:var(--gold);font-weight:600">${label}</td><td style="color:var(--ink);font-weight:600">${planet}</td>`;
    vargas.forEach(v => {
      const vd = p.vargas && p.vargas[v];
      const info = planetHouseInfo(planet, vd);
      if(info) {
        html += `<td style="color:var(--blue)">H${info.sits}</td><td style="color:var(--green)">H${info.owns}</td>`;
      } else {
        html += '<td style="color:#ccc">—</td><td style="color:#ccc">—</td>';
      }
    });
    html += '</tr>';
  });
  html += '</tbody></table>';
  return html;
}

