// ── PARSE / CLEAR ───────────────────────────────────────────────────
function doParse(){
  const p=cp();if(!p)return;
  const raw=document.getElementById('paste-varga').value.trim();
  const msg=document.getElementById('pmsg');
  if(!raw){msg.textContent='Nothing to parse';msg.className='pmsg err';return;}
  const parsed=parseVargaTable(raw);
  if(!parsed||!Object.keys(parsed.planets).length){msg.textContent='Parse failed — check format';msg.className='pmsg err';return;}
  p.rawVarga=raw;p.vargas={};
  Object.entries(parsed.planets).forEach(([pl,vm])=>{
    Object.entries(vm).forEach(([vn,pos])=>{
      if(!p.vargas[vn])p.vargas[vn]={};
      p.vargas[vn][pl]=pos;
    });
  });
  save();
  msg.textContent=`Parsed ${Object.keys(parsed.planets).length} planets × ${parsed.cols.length} vargas ✓`;
  msg.className='pmsg ok';
  document.getElementById('charts-grid').innerHTML=renderAllCharts(p);

}

function doClear(){
  const p=cp();if(!p)return;
  p.rawVarga='';p.vargas={};save();
  document.getElementById('paste-varga').value='';
  document.getElementById('pmsg').textContent='Cleared';
  document.getElementById('pmsg').className='pmsg';
  document.getElementById('charts-grid').innerHTML=renderAllCharts(p);
}





